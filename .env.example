# Google Cloud (Vertex AI / Gemini)
# Auth qua ADC (Application Default Credentials) — KHÔNG cần service-account.json.
#   - Trên Cloud Run: tự lấy credentials từ service account gắn vào service.
#   - Test local: chạy `gcloud auth application-default login`.
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_REGION=us-central1

# Qdrant (vector store for RAG)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# SerpApi (internet search tool)
SERPAPI_KEY=your-serpapi-key

# Backend API (Spring Boot). Set to the reachable BE URL.
# Local same-host: http://localhost:8080 | Docker: http://host.docker.internal:8080
BE_BASE_URL=http://localhost:8080

# Admin credentials the agent uses to auto-login to the BE
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Memory consolidation
CONSOLIDATE_INTERVAL_HOURS=24

# Daily market intel schedule (giờ crawl thị trường, mặc định 5:30 sáng)
MARKET_INTEL_HOUR=5
MARKET_INTEL_MINUTE=30
# Daily review schedule (giờ orchestrator review + gửi thông báo, mặc định 6:00 sáng)
DAILY_REVIEW_HOUR=6
DAILY_REVIEW_MINUTE=0

# Turso / libSQL (conversation memory)
TURSO_AUTH_TOKEN=your-turso-auth-token
TURSO_DATABASE_URL=libsql://your-db.turso.io

# Zalo Bot
ZALO_BOT_TOKEN=your-zalo-bot-token
ZALO_WEBHOOK_SECRET=your-zalo-webhook-secret
# Chat ID của admin để nhận thông báo proactive (lấy từ webhook message.chat.id)
ZALO_ADMIN_CHAT_ID=28d577b17bee92b0cbff

# Gmail SMTP
GMAIL_SENDER_EMAIL=your-sender@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
GMAIL_ADMIN_EMAIL=your-admin@gmail.com
